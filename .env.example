# Google Drive Settings
# The folder ID of the parent folder in Google Drive where "Mehndi Collection" will be created.
# Leave blank to create it in the root of your Google Drive.
GDRIVE_PARENT_FOLDER_ID=

# Paths
# Path to Google Client Secrets JSON file (downloaded from Google Cloud Console).
# Default is 'credentials.json' in the project directory.
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Local storage configuration
DATABASE_PATH=mehndi_agent.db
DOWNLOADS_DIR=downloads

# Scraping settings
# Set to True to hide the browser window during scraping, False to watch the browser actions
PINTEREST_HEADLESS=True
# Seconds to delay between page scroll movements and fetching elements
PINTEREST_DELAY_SECONDS=3.0
# Maximum retries for scraping network requests
MAX_RETRIES=3

# Streamlit App Configuration
PORT=8501
HOST=localhost
